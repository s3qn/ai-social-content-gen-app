# Which scrape provider serves /scan, peers and trending: scrapecreators | apify.
# Unset (or anything other than "apify") means scrapecreators. Flip to apify to
# fall back to the actor without a code change.
SCRAPER_PROVIDER=scrapecreators

# ScrapeCreators key (app.scrapecreators.com). Flat 1 credit per request; every
# call logs its latency and credits_remaining so the provider test can track
# spend. Server-side only.
SCRAPECREATORS_API_KEY=

# Apify token (holds the Instagram scraper actor credits). Only used when
# SCRAPER_PROVIDER=apify. Server-side only.
APIFY_API_KEY=

# Which provider runs the Claude Content-DNA step: cli | api. Default: cli.
#   cli: shells out to the locally-authenticated `claude` binary. Spends NO
#         API credits, so this is what we use in development. Requires `claude`
#         on the server's PATH and logged in.
#   api: the Anthropic SDK, billed against ANTHROPIC_API_KEY below. Flip to
#         this at go-live.
# Either way the step is best-effort: if it fails, /scan still returns real
# stats with dna/score null.
DNA_PROVIDER=cli

# Anthropic key: only needed when DNA_PROVIDER=api. Ignored (and deliberately
# stripped from the CLI subprocess env) on the default cli path, so a stray key
# here can never be billed by accident.
ANTHROPIC_API_KEY=

# Shared secret for the Bearer gate. Generate with: python -c "import secrets; print(secrets.token_hex(16))"
# The Expo app sends it as EXPO_PUBLIC_SCAN_TOKEN.
SCAN_TOKEN=

# Supabase, for writing the GLOBAL trending cache (trending_batches, 0008).
# SUPABASE_URL is the same project URL the app uses.
#
# SUPABASE_SERVICE_ROLE_KEY bypasses row-level security, which is the entire
# point: 0008 grants every authenticated user SELECT and grants NOBODY insert or
# update, so this service is the only writer and no client can poison a cache
# that is served to every user as editorial content.
#
# NEVER expose this key to the app. Anything named EXPO_PUBLIC_* ships inside the
# JS bundle and is readable by anyone who installs it.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
