# Apify token (holds the Instagram scraper actor credits). Server-side only.
APIFY_API_KEY=

# Which provider runs the Claude Content-DNA step: cli | api. Default: cli.
#   cli: shells out to the locally-authenticated `claude` binary. Spends NO
#         API credits, so this is what we use in development. Requires `claude`
#         on the server's PATH and logged in.
#   api: the Anthropic SDK, billed against ANTHROPIC_API_KEY below. Flip to
#         this at go-live.
# Either way the step is best-effort: if it fails, /scan still returns real
# stats with dna/score null.
DNA_PROVIDER=cli

# Anthropic key: only needed when DNA_PROVIDER=api. Ignored (and deliberately
# stripped from the CLI subprocess env) on the default cli path, so a stray key
# here can never be billed by accident.
ANTHROPIC_API_KEY=

# Shared secret for the Bearer gate. Generate with: python -c "import secrets; print(secrets.token_hex(16))"
# The Expo app sends it as EXPO_PUBLIC_SCAN_TOKEN.
SCAN_TOKEN=
