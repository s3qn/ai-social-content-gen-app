EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Instagram scan service (lib/scan.ts). URL of the Bearer-gated /scan endpoint
# and its token. Never commit the real token. Set these in your local .env.
EXPO_PUBLIC_SCAN_URL=
EXPO_PUBLIC_SCAN_TOKEN=

# Peer suggestions (lib/peer-suggest.ts). Full URL of the /peers/suggest
# endpoint on the same service; it reuses EXPO_PUBLIC_SCAN_TOKEN above.
# SCAN_URL is a full endpoint URL rather than a base, so this is a second var
# instead of a path join.
EXPO_PUBLIC_PEERS_URL=
